          SQLTask:SqlStatementSource="TRUNCATE TABLE [dbo].[Dim_Date];&#xA;&#xA;-- Turn on Identity Insert so we can force our custom Date Keys&#xA;SET IDENTITY_INSERT [dbo].[Dim_Date] ON;&#xA;&#xA;DECLARE @StartDate DATE = '2016-01-01';&#xA;DECLARE @EndDate DATE = '2020-12-31';&#xA;DECLARE @CurrentDate DATE = @StartDate;&#xA;&#xA;WHILE @CurrentDate &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO [dbo].[Dim_Date] (&#xA;        [date_key], &#xA;        [full_date], &#xA;        [year], &#xA;        [month], &#xA;        [day], &#xA;        [quarter]&#xA;    )&#xA;    VALUES (&#xA;        CAST(CONVERT(VARCHAR(8), @CurrentDate, 112) AS INT), -- date_key (e.g., 20160101)&#xA;        @CurrentDate,                                        -- full_date&#xA;        DATEPART(YEAR, @CurrentDate),                        -- year&#xA;        DATEPART(MONTH, @CurrentDate),                       -- month&#xA;        DATEPART(DAY, @CurrentDate),                         -- day&#xA;        DATEPART(QUARTER, @CurrentDate)                      -- quarter&#xA;    );&#xA;&#xA;    SET @CurrentDate = DATEADD(DAY, 1, @CurrentDate);&#xA;END;&#xA;&#xA;-- Always turn it back off when done!&#xA;SET IDENTITY_INSERT [dbo].[Dim_Date] OFF;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
