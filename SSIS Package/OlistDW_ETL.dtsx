                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    order_id,
    CAST(CONVERT(VARCHAR(8), order_approved_at, 112) AS INT) AS order_approved_date_key,
    CAST(CONVERT(VARCHAR(8), order_delivered_customer_date, 112) AS INT) AS order_delivered_date_key,
    DATEDIFF(day, order_purchase_timestamp, order_approved_at) AS days_to_approve,
    DATEDIFF(day, order_purchase_timestamp, order_delivered_customer_date) AS days_to_deliver
FROM orders
WHERE order_approved_at IS NOT NULL OR order_delivered_customer_date IS NOT NULL;</property>
