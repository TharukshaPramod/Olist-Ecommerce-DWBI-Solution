      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9D83415E-0C1C-4647-A6FB-FFBA25ED982A}"
          SQLTask:SqlStatementSource="UPDATE f&#xA;SET &#xA;    f.order_approved_date_key = stg.order_approved_date_key,&#xA;    f.order_delivered_date_key = stg.order_delivered_date_key,&#xA;    f.days_to_approve = stg.days_to_approve,&#xA;    f.days_to_deliver = stg.days_to_deliver&#xA;FROM [dbo].[Fact_Sales] f&#xA;INNER JOIN [dbo].[stg_Fact_Updates] stg ON f.order_id = stg.order_id;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
